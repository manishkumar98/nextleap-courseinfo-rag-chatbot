{
    "builds": [
        {
            "src": "src/phase5_frontend/package.json",
            "use": "@vercel/next"
        },
        {
            "src": "api/index.py",
            "use": "@vercel/python"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "api/index.py"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "src/phase5_frontend/$1"
        }
    ]
}